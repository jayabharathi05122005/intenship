<style>
/* ==========================
   CSS VARIABLES (THEME)
========================== */

:root{
    --bg:#f5f7fb;
    --card:#ffffff;
    --text:#111827;
    --text-light:#4b5563;
    --primary:#2563eb;
    --secondary:#9333ea;
    --shadow:0 10px 25px rgba(0,0,0,0.1);
    --border:#e5e7eb;
}

body.dark{
    --bg:#0f172a;
    --card:#1e293b;
    --text:#f8fafc;
    --text-light:#cbd5e1;
    --primary:#60a5fa;
    --secondary:#a855f7;
    --shadow:0 10px 25px rgba(0,0,0,0.4);
    --border:#334155;
}

/* ==========================
   RESET
========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:Arial,sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.7;
    transition:0.3s;
}

/* ==========================
   ACCESSIBILITY
========================== */

.skip-link{
    position:absolute;
    top:-50px;
    left:10px;
    background:black;
    color:white;
    padding:10px;
    z-index:1000;
}

.skip-link:focus{
    top:10px;
}

/* ==========================
   HEADER
========================== */

header{
    position:sticky;
    top:0;
    z-index:100;
    background:var(--card);
    box-shadow:var(--shadow);
}

.navbar{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:18px 0;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:28px;
    font-weight:bold;
    color:var(--primary);
}

nav ul{
    display:flex;
    gap:20px;
    list-style:none;
}

nav a{
    text-decoration:none;
    color:var(--text);
    font-weight:bold;
}

nav a:hover,
nav a:focus{
    color:var(--primary);
}

/* Theme button */

.theme-btn{
    border:none;
    background:var(--primary);
    color:white;
    padding:10px 16px;
    border-radius:8px;
    cursor:pointer;
}

/* ==========================
   HERO
========================== */

.hero{
    width:90%;
    max-width:1200px;
    margin:auto;
    min-height:90vh;
    display:grid;
    grid-template-columns:1fr;
    gap:30px;
    align-items:center;
    padding:50px 0;
}

.hero-text h1{
    font-size:50px;
}

.hero-text span{
    color:var(--primary);
}

.hero-text p{
    margin:20px 0;
    color:var(--text-light);
}

.btn{
    display:inline-block;
    padding:14px 28px;
    background:linear-gradient(
        to right,
        var(--primary),
        var(--secondary)
    );
    color:white;
    text-decoration:none;
    border-radius:10px;
}

.hero-image{
    display:flex;
    justify-content:center;
}

.hero-image img{
    width:300px;
    border-radius:20px;
    box-shadow:var(--shadow);
}

/* ==========================
   SECTION
========================== */

section{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:80px 0;
}

.section-title{
    text-align:center;
    margin-bottom:50px;
    font-size:40px;
}

/* ==========================
   ABOUT
========================== */

.about-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:20px;
}

.about-card{
    background:var(--card);
    padding:30px;
    border-radius:20px;
    box-shadow:var(--shadow);
}

/* ==========================
   PROJECTS GRID
========================== */

.projects-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:25px;
}

.project-card{
    background:var(--card);
    padding:25px;
    border-radius:20px;
    box-shadow:var(--shadow);
    transition:0.3s;
}

.project-card:hover{
    transform:translateY(-5px);
}

.project-card h3{
    margin-bottom:10px;
}

/* ==========================
   SKILLS FLEXBOX
========================== */

.skills{
    display:flex;
    flex-wrap:wrap;
    gap:15px;
    justify-content:center;
}

.skill{
    background:var(--card);
    padding:15px 25px;
    border-radius:50px;
    box-shadow:var(--shadow);
}

/* ==========================
   CONTACT FORM
========================== */

form{
    display:grid;
    gap:20px;
}

input,
textarea{
    width:100%;
    padding:15px;
    border:2px solid var(--border);
    border-radius:12px;
    background:var(--card);
    color:var(--text);
}

button{
    border:none;
    padding:16px;
    border-radius:12px;
    background:var(--primary);
    color:white;
    cursor:pointer;
}

input:focus,
textarea:focus,
button:focus{
    outline:3px solid #facc15;
}

/* ==========================
   FOOTER
========================== */

footer{
    background:var(--card);
    padding:30px;
    text-align:center;
    margin-top:50px;
}

/* ==========================
   MOBILE FIRST MEDIA QUERY
========================== */

@media(min-width:768px){

    .hero{
        grid-template-columns:1fr 1fr;
    }

    .about-grid{
        grid-template-columns:1fr 1fr;
    }

    .projects-grid{
        grid-template-columns:
        repeat(2,1fr);
    }

    .hero-text h1{
        font-size:65px;
    }
}

@media(min-width:1024px){

    .projects-grid{
        grid-template-columns:
        repeat(3,1fr);
    }
}
</style>
</head>

