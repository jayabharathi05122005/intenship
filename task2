<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <meta name="description"
        content="Personal portfolio website showcasing skills, projects and contact details." />

    <meta name="keywords"
        content="portfolio, web developer, HTML5, accessibility, projects" />

    <meta name="author"
        content="Your Name" />

    <meta name="robots"
        content="index, follow" />

    <title>Personal Portfolio</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.7;
            background: #f5f5f5;
            color: #222;
        }

        /* Skip navigation link */
        .skip-link {
            position: absolute;
            top: -50px;
            left: 10px;
            background: black;
            color: white;
            padding: 10px;
            text-decoration: none;
        }

        .skip-link:focus {
            top: 10px;
        }

        header {
            background: #1f2937;
            color: white;
            text-align: center;
            padding: 30px;
        }

        nav {
            background: #111827;
            padding: 15px;
        }

        nav ul {
            display: flex;
            justify-content: center;
            list-style: none;
            gap: 20px;
        }

        nav a {
            color: white;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:focus,
        nav a:hover {
            outline: 3px solid yellow;
        }

        main {
            width: 90%;
            max-width: 1000px;
            margin: auto;
            padding: 30px 0;
        }

        section {
            background: white;
            margin-bottom: 25px;
            padding: 25px;
            border-radius: 10px;
        }

        h2 {
            margin-bottom: 15px;
        }

        article {
            margin-bottom: 20px;
        }

        form {
            display: grid;
            gap: 15px;
        }

        label {
            font-weight: bold;
        }

        input,
        textarea,
        button {
            padding: 12px;
            font-size: 16px;
        }

        input:focus,
        textarea:focus,
        button:focus {
            outline: 3px solid blue;
        }

        button {
            background: #2563eb;
            color: white;
            border: none;
            cursor: pointer;
        }

        footer {
            background: #1f2937;
            color: white;
            text-align: center;
            padding: 20px;
        }
    </style>
</head>

<body>

    <!-- Accessibility Skip Link -->
    <a href="#main-content"
        class="skip-link">
        Skip to main content
    </a>

    <!-- Header -->
    <header role="banner"
        aria-label="Portfolio Header">

        <h1>
        JAYA
        </h1>

        <p>
            Web Developer | Designer | Programmer
        </p>
    </header>

    <!-- Navigation -->
    <nav role="navigation"
        aria-label="Main Navigation">

        <ul>
            <li>
                <a href="#about">
                    About
                </a>
            </li>

            <li>
                <a href="#projects">
                    Projects
                </a>
            </li>

            <li>
                <a href="#skills">
                    Skills
                </a>
            </li>

            <li>
                <a href="#contact">
                    Contact
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main id="main-content"
        role="main">

        <!-- About Section -->
        <section id="about"
            aria-labelledby="about-heading">

            <h2 id="about-heading">
                About Me
            </h2>

            <article>
                <p>
                    Hello! I am a passionate web developer
                    skilled in HTML, CSS, JavaScript,
                    accessibility standards and modern
                    web technologies.
                </p>
            </article>
        </section>

        <!-- Projects -->
        <section id="projects"
            aria-labelledby="project-heading">

            <h2 id="project-heading">
                Projects
            </h2>

            <article>
                <h3>
                    Portfolio Website
                </h3>

                <p>
                    A fully responsive and accessible
                    website built using semantic HTML5.
                </p>
            </article>

            <article>
                <h3>
                    Weather Dashboard
                </h3>

                <p>
                    A real-time dashboard using REST APIs,
                    async JavaScript and JSON parsing.
                </p>
            </article>
        </section>

        <!-- Skills -->
        <section id="skills"
            aria-labelledby="skills-heading">

            <h2 id="skills-heading">
                Skills
            </h2>

            <article>
                <ul>
                    <li>HTML5</li>
                    <li>CSS3</li>
                    <li>JavaScript</li>
                    <li>Accessibility (WCAG)</li>
                    <li>Responsive Web Design</li>
                </ul>
            </article>
        </section>

        <!-- Contact -->
        <section id="contact"
            aria-labelledby="contact-heading">

            <h2 id="contact-heading">
                Contact Me
            </h2>

            <!-- Accessible Contact Form -->
            <form
                aria-label="Contact Form">

                <div>
                    <label for="name">
                        Full Name
                    </label>

                    <input
                        type="text"
                        id="name"
                        name="name"
                        aria-required="true"
                        required>
                </div>

                <div>
                    <label for="email">
                        Email Address
                    </label>

                    <input
                        type="email"
                        id="email"
                        name="email"
                        aria-required="true"
                        required>
                </div>

                <div>
                    <label for="message">
                        Message
                    </label>

                    <textarea
                        id="message"
                        name="message"
                        rows="5"
                        aria-required="true"
                        required></textarea>
                </div>

                <button type="submit"
                    aria-label="Send Message">
                    Send Message
                </button>
            </form>
        </section>
    </main>

    <!-- Footer -->
    <footer role="contentinfo"
        aria-label="Footer">

        <p>
            © 2026 Your Name.
            All Rights Reserved.
        </p>
    </footer>

</body>
</html>
